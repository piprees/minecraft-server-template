# .env.example — every setting and secret in one place.
#
# Copy to .env and fill in your values:
#   cp .env.example .env            — manual setup
#   ./scripts/setup.sh              — interactive wizard (writes .env for you)
#   ./scripts/op-env.sh > .env      — restore from 1Password
#
# Conventions in this file:
#   VAR=            you must fill this in (blank = required, no default)
#   # VAR=          optional — uncomment to override the platform default
#   # e.g. VAR='…'  what a real value looks like
#
# Platform defaults live in docker-compose.yml (${VAR:-default}) and the
# scripts — a lean .env with only the filled-in lines is a complete config.
# Docker Compose reads .env automatically. Scripts source it too.
# .env is git-ignored. This file (.env.example) is the committed reference.
# Which token/key is which (and the traps): docs/credentials.md

# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT — fill these in, ignore everything below for local-only use
# ═══════════════════════════════════════════════════════════════════════════════

# --- Branding -----------------------------------------------------------------
# e.g. BRAND_NAME='Adventure Server'
BRAND_NAME=
# Lowercase, no spaces - names Docker project, tunnel, 1Password item.
# e.g. BRAND_SLUG=adventure
BRAND_SLUG=
# Server list text. e.g. MOTD='An adventure awaits'
# MOTD=
# Public URL for the brand icon (PNG/JPG/WebP). Used as the Discord webhook
# avatar so all bot messages show the same profile picture. Copy from the
# Discord Developer Portal (your app > General > icon URL) or host your own.
# e.g. BRAND_ICON_URL='https://cdn.discordapp.com/avatars/123/abc.png'
# BRAND_ICON_URL=
# Shown on the modpack download page; empty = hidden.
# e.g. DISCORD_INVITE_URL='https://discord.gg/xxxxxxx'
DISCORD_INVITE_URL=

# --- Networking ---------------------------------------------------------------
# Your real domain (Cloudflare zone). e.g. DOMAIN=example.com
DOMAIN=
# Local-dev subdomain base. Default: <BRAND_SLUG>.local
# e.g. LOCAL_DOMAIN=myserver.local
# LOCAL_DOMAIN=

# --- Stack version (the platform release your server runs) --------------------
# A major pin like v2 floats on the latest v2.x.y release, so updates arrive
# with ./dev update / deploys. Pin exactly (STACK_VERSION=v2.0.1) for
# reproducible deploys; bump majors deliberately when a new one ships.
# ./ops setup records this for you.
STACK_VERSION=v2

# --- Server identity ----------------------------------------------------------
# Default: 1.21.1 (the version all default mods are pinned to)
# MC_VERSION=1.21.1
# Blank = random world seed. e.g. SEED=-4530634556500121041
SEED=

# --- Mod sync (offline by default) ----------------------------------------------
# Boots make zero network requests: missing jars are fetched host-side by
# sync-mods.sh (dev-up/deploy) before mc starts. Uncomment to hand the sync
# back to itzg instead (per-URL freshness HEAD checks on every boot).
# MODS_FILE=/extras/mods-urls.txt
# DATAPACKS_FILE=/extras/datapacks-urls.txt

# --- Access control -----------------------------------------------------------
# Discord role sync is the normal path (see README). These are direct
# fallbacks; comma-separated Minecraft usernames.
# e.g. OPS=Steve
# OPS=
# e.g. WHITELIST=Steve,Alex
# WHITELIST=
# Defaults: TRUE in production (compose), FALSE for local dev (compose.local)
# ENABLE_WHITELIST=TRUE
# ENFORCE_WHITELIST=TRUE

# --- Ports (defaults shown; override only on conflicts) ------------------------
# SERVER_PORT=25577
# GAME_PORT=25577
# VOICE_PORT=24454
# WEB_PORT=8080
# KUMA_PORT=3001

# --- Performance (defaults shown) ----------------------------------------------
# MEMORY=5G
# VIEW_DISTANCE=10
# SIMULATION_DISTANCE=8

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION — only needed if deploying to a cloud server
# ═══════════════════════════════════════════════════════════════════════════════

# --- Infrastructure -----------------------------------------------------------
# "hetzner", "digitalocean", or "local" (default: local)
# CLOUD_PROVIDER=hetzner

# Hetzner (defaults shown; cx33 = 4c/8GB x86 ~€11/mo)
# HCLOUD_LOCATION=fsn1
# HCLOUD_SERVER_TYPE=cx33

# DigitalOcean (only when CLOUD_PROVIDER=digitalocean)
# DO_REGION=lon1
# DO_SIZE=s-4vcpu-8gb

# Written by provision.sh - the server's public IP.
# e.g. DROPLET_HOST=203.0.113.10
# DROPLET_HOST=
# DEPLOY_USER=deploy

# Default: mc-<BRAND_SLUG>
# CLOUDFLARE_TUNNEL_NAME=

# --- Idle behaviour -----------------------------------------------------------
# Seconds before autopause (default 600). idle-tasks runs 3min after empty.
# AUTOPAUSE_TIMEOUT=600

# --- Backups (defaults shown; retention fits R2's free 10GB) -------------------
# BACKUP_INTERVAL=12h
# RESTIC_RETENTION_DAILY=3
# RESTIC_RETENTION_WEEKLY=1
# RESTIC_RETENTION_MONTHLY=1

# --- Logging ------------------------------------------------------------------
# 'prod' (default) suppresses noise; 'dev' shows everything.
# LOG_LEVEL=prod

# --- Spawn override (betterspawn) ---------------------------------------------
# Set in-game with /setworldspawn, record here so deploys preserve them.
# e.g. SPAWN_X=-291
SPAWN_X=
SPAWN_Y=
SPAWN_Z=

# --- World border (defaults shown; see README before changing) -----------------
# Player-facing borders are MOD-OWNED since v3: borders.player in
# config/custom-dimensions/dimensions/*.json (override via the overlay).
# PREGEN_BORDER_RADIUS remains the pre-generation/tooling radius for
# idle-tasks and the BlueMap-bounds fallback when a dimension config has
# no borders block. (PLAYER_BORDER_RADIUS was removed in v3.)
# PREGEN_BORDER_RADIUS=8192

# --- Static map renders (uNmINeD — this IS map.DOMAIN) --------------------------
# The unmined-render sidecar renders every world + visited custom dimension
# to static webp tile maps in ./data/unmined-web; nav-proxy serves them as
# map.DOMAIN (SPA shell, per-dimension URLs, long edge-cache with ?v=
# busting). Renders are incremental and clamped to borders.generation /
# PREGEN_BORDER_RADIUS. Interval uses sleep(1) syntax; 0 disables.
# UNMINED_INTERVAL=6h
# Zoom-out levels in the web viewer (default 6).
# UNMINED_ZOOMOUT=6

# --- Discord role IDs ----------------------------------------------------------
# Enable Developer Mode in Discord, right-click role > Copy ID.
# e.g. DISCORD_ADMIN_ROLE_ID=000000000000000000
DISCORD_ADMIN_ROLE_ID=
DISCORD_PLAYER_ROLE_ID=
# DISCORD_BOT_ROLE_ID=

# --- Discord welcome pin (managed by scripts/discord-pin-sync.sh) -------------
# The #general channel and the BOT-authored pinned message it edits.
# DISCORD_WELCOME_MESSAGE_ID is printed by --init; empty until then.
# DISCORD_WELCOME_CHANNEL_ID=
# DISCORD_WELCOME_MESSAGE_ID=

# --- Secrets (never committed; full guide: docs/credentials.md) -----------------

# Hetzner Cloud API token (Console > project > Security > API tokens,
# Read & Write). 64 alphanumeric chars.
HCLOUD_TOKEN=
# DigitalOcean (only when CLOUD_PROVIDER=digitalocean).
# e.g. DO_API_TOKEN='dop_v1_…'
# DO_API_TOKEN=

# Cloudflare API token. Create: My Profile > API Tokens > Create Custom Token
# with Account/Cloudflare Tunnel:Edit, Account/Workers R2 Storage:Edit,
# Account/Workers Scripts:Edit, Zone/DNS:Edit, Zone/Zone:Read.
# 40+ chars; newer tokens start with cfut_.
# This is the custom API token, not the Global API Key and not the token
# from the R2 page (that one is for backups, below).
CLOUDFLARE_API_TOKEN=
# Both 32 hex chars, from any zone's Overview page (right column).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# Generated by cloudflare-setup.sh - never hand-created.
# CLOUDFLARE_TUNNEL_ID=

# Discord bot (chat bridge, role sync, admin commands).
# discord.com/developers > your app > Bot > Reset Token (~70 chars, two dots)
DISCORD_BOT_TOKEN=
# Admin channel (deploy notifications, audit log, mod update alerts).
# e.g. DISCORD_CHANNEL_ID=000000000000000000
DISCORD_CHANNEL_ID=
# Player chat channel (game chat bridge, modpack update pings).
# Falls back to DISCORD_CHANNEL_ID when unset.
# DISCORD_CHAT_CHANNEL_ID=
DISCORD_GUILD_ID=
# Channel > Integrations > Webhooks.
# e.g. DISCORD_WEBHOOK_URL='https://discord.com/api/webhooks/…'
DISCORD_WEBHOOK_URL=

# Cloudflare R2 S3 keypair, used by restic for backups. A separate credential
# from CLOUDFLARE_API_TOKEN. Create: R2 > Manage API Tokens > Create Account
# API token > Object Read & Write. The result page shows three values; copy
# the Access Key ID (32 hex) and Secret Access Key (64 hex) here. The Token
# value at the top of that page is not used.
# Same value as CLOUDFLARE_ACCOUNT_ID.
R2_ACCOUNT_ID=
# e.g. R2_BUCKET=mc-backups
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Backup encryption passphrase. Cannot be recovered if lost, so keep it in
# 1Password. e.g. RESTIC_PASSWORD="$(openssl rand -base64 24)"
RESTIC_PASSWORD=
# Auto-generated by ./dev up when blank.
RCON_PASSWORD=
KUMA_PASSWORD=
# KUMA_USERNAME=admin

# Kuma socket.io session token (NOT the Prometheus API key in Kuma's UI).
# Generated by kuma-token.sh after first deploy.
# KUMA_API_KEY=

# SSH deploy key public path (used by setup.sh to configure the server).
# DEPLOY_KEY_PUB='~/.ssh/mc_deploy_key.pub'

# --- 1Password backup (per-server item; see docs/credentials.md) ----------------
# Defaults: vault "Dev", item "Minecraft Server (<BRAND_SLUG>)"
# OP_VAULT=Dev
# OP_ITEM_NAME='Minecraft Server (myslug)'

# --- Platform images (defaults shown; only the template repo builds) ------------
# IMAGE_REGISTRY=ghcr.io/piprees/minecraft-server-template
# IMAGE_TAG=latest

# --- Third-party image mirror (Docker Hub resilience) ---------------------------
# All third-party Docker Hub images (itzg, minio, nginx, etc.) are mirrored
# weekly to GHCR by mirror-images.yml. Set to 'docker.io' to pull direct.
# MIRROR_REGISTRY=ghcr.io/piprees/mirrors

# --- Paths (defaults shown; override for unusual layouts) -----------------------
# OVERLAY_DIR=./overlay
# DIST_DIR=./modpack-dist
# CLOUDFLARED_DIR=./cloudflared

# --- Local overrides ------------------------------------------------------------
# ONLINE_MODE is set via docker-compose.local.yml for local runs only.
# Production always defaults to TRUE via docker-compose.yml.

# --- Modpack --------------------------------------------------------------------
# MODPACK_VERSION is derived from the git commit hash by build-modpack.sh.
