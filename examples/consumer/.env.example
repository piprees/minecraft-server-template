# Your server. Copy to .env and fill in the blanks — or run ./ops setup,
# which walks you through creating every credential and writes this file.
#
# Conventions:
#   VAR=            you must fill this in
#   # VAR=          optional — uncomment to override the platform default
#   # e.g. VAR='…'  what a real value looks like
#
# Platform defaults (MC version, memory, ports, …) live in the stack bundle;
# a lean .env with only these lines is a complete config.
# Which token/key is which: see docs/credentials.md in the template repo.

# === Identity (make it yours) ===
# e.g. BRAND_NAME='Elfydd'
BRAND_NAME=
# Lowercase, no spaces. e.g. BRAND_SLUG=elfydd
BRAND_SLUG=
# Your Cloudflare-managed domain. e.g. DOMAIN=example.com
DOMAIN=
# Local-dev subdomains. Default: <BRAND_SLUG>.local
# LOCAL_DOMAIN=
# Blank = random world seed. e.g. SEED=-4530634556500121041
SEED=
# Where players spawn. Deploys re-apply these coordinates on every deploy,
# so change them here (an in-game /setworldspawn doesn't stick).
SPAWN_X=
SPAWN_Y=
SPAWN_Z=

# Stack (template) release your server runs. A major pin like v2 floats on
# the latest v2.x.y release, so updates arrive with ./dev update / deploys.
# Pin exactly (STACK_VERSION=v2.0.1) for reproducible deploys; bump majors
# deliberately.
STACK_VERSION=v2

# === Discord ===
# Role IDs: enable Developer Mode, right-click role > Copy ID.
# e.g. DISCORD_ADMIN_ROLE_ID=000000000000000000
DISCORD_ADMIN_ROLE_ID=
DISCORD_PLAYER_ROLE_ID=
# e.g. DISCORD_INVITE_URL='https://discord.gg/xxxxxxx'
DISCORD_INVITE_URL=
# Bot token: discord.com/developers > your app > Bot > Reset Token
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=
# Channel > Integrations > Webhooks
# e.g. DISCORD_WEBHOOK_URL='https://discord.com/api/webhooks/…'
DISCORD_WEBHOOK_URL=

# === Infrastructure (provisioned by ./ops setup) ===
# "hetzner" (default assumed by ./ops provision), "digitalocean", or "local"
# CLOUD_PROVIDER=hetzner

# Hetzner API token: console.hetzner.cloud > project > Security > API tokens,
# Read & Write. 64 alphanumeric chars.
HCLOUD_TOKEN=

# Cloudflare API token. Create at dash.cloudflare.com > My Profile >
# API Tokens > Create Custom Token with Account/Cloudflare Tunnel:Edit,
# Account/Workers R2 Storage:Edit, Account/Workers Scripts:Edit,
# Zone/DNS:Edit, Zone/Zone:Read. 40+ chars, newer tokens start with cfut_.
# This is the custom API token, not the Global API Key and not the token
# from the R2 page.
CLOUDFLARE_API_TOKEN=
# Both 32 hex chars, from any zone's Overview page (right column).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# R2 S3 keypair for backups, a separate credential from the API token above.
# Create at R2 > Manage API Tokens > Create Account API token > Object Read
# & Write. Copy the Access Key ID (32 hex) and Secret Access Key (64 hex).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Same value as CLOUDFLARE_ACCOUNT_ID.
R2_ACCOUNT_ID=
# e.g. R2_BUCKET=myserver-backups
R2_BUCKET=

# Backup encryption passphrase. Cannot be recovered if lost, so keep it safe.
# e.g. RESTIC_PASSWORD="$(openssl rand -base64 24)"
RESTIC_PASSWORD=
# Auto-generated by ./dev up when blank.
RCON_PASSWORD=
KUMA_PASSWORD=
