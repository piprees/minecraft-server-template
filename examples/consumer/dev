#!/usr/bin/env bash
# dev — Local development entrypoint.
# Thin wrapper that resolves paths/env and delegates to bundle scripts.
# Contains NO stack logic.
set -euo pipefail

CONSUMER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$CONSUMER_DIR"

STACK_SCRIPTS=".stack/current/stack/scripts"

usage() {
  echo "Usage: ./dev <command>"
  echo ""
  echo "Commands:"
  echo "  up       Start the local dev stack"
  echo "  down     Stop the local dev stack"
  echo "  logs     Tail the Minecraft server logs"
  echo "  rcon     Run an RCON command (e.g. ./dev rcon \"list\")"
  echo "  pack     Build the client modpack into ./modpack-dist/"
  echo "  pin      Re-pin overlay/mods-extra.txt to latest mod builds (review with git diff)"
  echo "  pull     Fetch the stack bundle only (first boot / cache recovery)"
  echo "  update   Pull the latest stack bundle + Docker images"
  echo "  sync     Update everything: local down, update, env sync to GitHub, server update, local up"
  echo "  seed-roll   Batch-test world seeds locally (resumable)"
  echo "  seed-report Generate the top-N seed report from results"
  echo "  cache    Snapshot Docker images, mod JARs, offline client bundles"
  echo "  start    Start a stopped service (e.g. ./dev start uptime-kuma)"
  echo "  stop     Stop a running service (e.g. ./dev stop uptime-kuma)"
  echo "  restart  Force-recreate a service (e.g. ./dev restart nav-proxy)"
  echo "  status   Show container status (e.g. ./dev status)"
  echo ""
  echo "Production equivalents: ./ops help"
  echo "  dev up      ↔  (push to main triggers CI)"
  echo "  dev logs    ↔  ops logs [--tail N]"
  echo "  dev rcon    ↔  ops rcon"
  echo "  dev status  ↔  ops status"
}

ensure_env() {
  if [[ ! -f "$CONSUMER_DIR/.env" ]]; then
    echo "No .env found. Run ./ops setup first, or:"
    echo "  cp .env.example .env"
    echo "  # then fill in your secrets"
    exit 1
  fi
}

# Pull/refresh the stack bundle. The full-featured puller lives IN the
# bundle (scripts/stack-pull.sh) — safe to run from the bundle it updates,
# because each release unpacks into an immutable .stack/<version>/ dir and
# only the .stack/current symlink moves. bootstrap_stack below is the
# minimal first-ever pull for when no bundle exists yet.
stack_pull() {
  if [[ -f "$CONSUMER_DIR/$STACK_SCRIPTS/stack-pull.sh" ]]; then
    (cd "$CONSUMER_DIR" && bash "$CONSUMER_DIR/$STACK_SCRIPTS/stack-pull.sh")
  else
    bootstrap_stack
  fi
}

bootstrap_stack() {
  local repo="piprees/minecraft-server-template"
  local pin="${STACK_VERSION:-}"
  if [[ -z "$pin" && -f "$CONSUMER_DIR/.env" ]]; then
    pin=$(grep -E '^STACK_VERSION=' "$CONSUMER_DIR/.env" | head -1 | cut -d= -f2- | tr -d '"' | tr -d "'") || true
  fi
  pin="${pin:-latest}"
  pin="${pin#v}"
  [[ "$pin" == "latest" ]] && pin=""
  echo "Bootstrapping stack bundle (pin: ${pin:-latest})..."

  local releases="" tag=""
  if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    releases=$(curl -fsSL --connect-timeout 10 --max-time 30 \
      -H "Authorization: Bearer ${GITHUB_TOKEN}" \
      "https://api.github.com/repos/$repo/releases" 2> /dev/null) || true
  fi
  if [[ -z "$releases" ]] && command -v gh > /dev/null 2>&1 && gh auth status > /dev/null 2>&1; then
    releases=$(gh api "/repos/$repo/releases" 2> /dev/null) || true
  fi
  if [[ -z "$releases" ]]; then
    releases=$(curl -fsSL --connect-timeout 10 --max-time 30 \
      "https://api.github.com/repos/$repo/releases" 2> /dev/null) || true
  fi
  tag=$(echo "$releases" \
    | grep -oE '"tag_name"\s*:\s*"v[0-9]+\.[0-9]+\.[0-9]+"' \
    | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' \
    | sort -t. -k1,1nr -k2,2nr -k3,3nr \
    | while IFS= read -r t; do
        if [[ -z "$pin" || "$t" == "$pin" || "$t" == "$pin".* ]]; then
          echo "v$t"
          break
        fi
      done)
  if [[ -z "$tag" ]]; then
    echo "ERROR: could not resolve a release matching '${pin:-latest}'" >&2
    exit 1
  fi

  local bare="${tag#v}"
  local dir="$CONSUMER_DIR/.stack/$tag"
  local tarball="stack-v${bare}.tar.gz"
  echo "Downloading $tag..."
  mkdir -p "$dir"
  local f
  for f in "$tarball" "$tarball.sha256"; do
    curl -fSL --connect-timeout 10 --max-time 120 -o "$dir/$f" \
      "https://github.com/$repo/releases/download/$tag/$f"
  done
  if ! (cd "$dir" && { shasum -a 256 -c "$tarball.sha256" > /dev/null 2>&1 || sha256sum -c "$tarball.sha256" > /dev/null 2>&1; }); then
    echo "ERROR: checksum verification failed — removing corrupted download" >&2
    rm -rf "$dir"
    exit 1
  fi
  tar -xzf "$dir/$tarball" -C "$dir"
  ln -sfn "$tag" "$CONSUMER_DIR/.stack/current"
  echo "$tag ready at .stack/current"
}

ensure_stack() {
  if [[ ! -d "$CONSUMER_DIR/.stack/current" ]]; then
    echo "Stack bundle not found. Pulling..."
    stack_pull
  fi
}

ensure_docker() {
  if docker info &> /dev/null; then
    return
  fi
  echo "Docker is not running. Starting..."
  if [[ "$(uname)" == "Darwin" ]]; then
    open -a Docker
  else
    systemctl start docker 2> /dev/null || sudo systemctl start docker
  fi
  local tries=0
  while ! docker info &> /dev/null && [[ $tries -lt 30 ]]; do
    sleep 2
    tries=$((tries + 1))
  done
  if ! docker info &> /dev/null; then
    echo "Docker failed to start after 60s."
    exit 1
  fi
  echo "Docker started."
}

# Change-detection checksum of this script. cksum is POSIX, so it behaves
# identically on macOS and Linux (md5/md5sum don't share a name or format).
self_sum() {
  cksum "$CONSUMER_DIR/dev" 2> /dev/null | awk '{print $1"-"$2}'
}

# If an update just replaced this script on disk, re-exec the same command
# so the rest of the run (and everything after it) uses the new code - the
# in-memory copy of a self-updated script is stale by definition.
# DEV_SELF_REEXEC guards against loops; a second pass sees equal sums anyway.
reexec_if_self_updated() {
  local before="$1"
  shift
  if [[ "$(self_sum)" != "$before" && -z "${DEV_SELF_REEXEC:-}" ]]; then
    echo "==> dev script was updated - re-running '$1' with the new version..."
    DEV_SELF_REEXEC=1 exec bash "$CONSUMER_DIR/dev" "$@"
  fi
}

CMD="${1:-help}"
shift || true

case "$CMD" in
  up)
    ensure_env
    ensure_stack
    ensure_docker
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/dev-up.sh" up
    ;;
  down)
    ensure_stack
    ensure_docker
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/dev-up.sh" down
    ;;
  logs)
    ensure_stack
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/dev-up.sh" logs
    ;;
  rcon)
    ensure_stack
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/rcon.sh" --local "$@"
    ;;
  pack)
    ensure_env
    ensure_stack
    ensure_docker
    # Load env for IMAGE_REGISTRY, LOCAL_DOMAIN, etc.
    set -a
    # shellcheck disable=SC1091
    source "$CONSUMER_DIR/.env"
    set +a
    mkdir -p "$CONSUMER_DIR/modpack-dist"
    docker run --rm \
      -v "$CONSUMER_DIR/overlay:/overlay:ro" \
      -v "$CONSUMER_DIR/modpack-dist:/work/dist" \
      -e "DOMAIN=${LOCAL_DOMAIN:-${DOMAIN:-localhost}}" \
      -e "BRAND_NAME=${BRAND_NAME:-My Server}" \
      -e "BRAND_SLUG=${BRAND_SLUG:-myserver}" \
      -e "MC_VERSION=${MC_VERSION:-1.21.1}" \
      -e "SERVER_PORT=${SERVER_PORT:-25577}" \
      -e "LOCAL_DOMAIN=${LOCAL_DOMAIN:-localhost}" \
      -e "GIT_SHA=${GIT_SHA:-local}" \
      -e "DISCORD_INVITE_URL=${DISCORD_INVITE_URL:-}" \
      "${IMAGE_REGISTRY:-ghcr.io/piprees/minecraft-server-template}/modpack-builder:${IMAGE_TAG:-latest}"
    echo "Modpack built to ./modpack-dist/"
    ;;
  pin)
    ensure_stack
    if [[ ! -f "$CONSUMER_DIR/overlay/mods-extra.txt" ]]; then
      echo "No overlay/mods-extra.txt found - nothing to pin."
      exit 0
    fi
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/pin-mod-versions.sh" \
      --file "$CONSUMER_DIR/overlay/mods-extra.txt" "$@"
    ;;
  pull)
    stack_pull
    ;;
  update)
    SELF_BEFORE="$(self_sum)"
    stack_pull
    STACK_DIR="$CONSUMER_DIR/.stack/current/stack"
    # Sync consumer entry points from the bundle. Write-to-temp + mv, never
    # cp: this loop replaces the very script bash is executing, and cp
    # rewrites the inode in place - bash reads scripts incrementally, so the
    # running interpreter would hit shifted bytes and die with a bogus parse
    # error ("unexpected EOF"). mv swaps the directory entry instead; the
    # running script keeps its old inode until exit.
    # Executable entry points (write-to-temp + mv to avoid corrupting
    # the running script — see comment above reexec_if_self_updated).
    for f in dev ops; do
      src="$STACK_DIR/examples/consumer/$f"
      if [[ -f "$src" ]]; then
        cp "$src" "$CONSUMER_DIR/$f.new"
        chmod +x "$CONSUMER_DIR/$f.new"
        mv "$CONSUMER_DIR/$f.new" "$CONSUMER_DIR/$f"
      fi
    done
    # Migration: the puller moved into the bundle (scripts/stack-pull.sh);
    # remove the old vendored consumer-root copy.
    rm -f "$CONSUMER_DIR/stack-pull.sh"
    reexec_if_self_updated "$SELF_BEFORE" update "$@"
    # Non-executable files that track the platform.
    for f in .env.example .gitignore AGENTS.md; do
      src="$STACK_DIR/examples/consumer/$f"
      [[ -f "$src" ]] && cp "$src" "$CONSUMER_DIR/$f"
    done
    # README.md: copy only if missing (consumer customises this).
    if [[ ! -f "$CONSUMER_DIR/README.md" ]]; then
      src="$STACK_DIR/examples/consumer/README.md"
      [[ -f "$src" ]] && cp "$src" "$CONSUMER_DIR/README.md"
    fi
    # Workflows (mkdir -p for first-time consumers without .github/).
    mkdir -p "$CONSUMER_DIR/.github/workflows"
    for f in .github/workflows/deploy.yml .github/workflows/update.yml; do
      src="$STACK_DIR/examples/consumer/$f"
      [[ -f "$src" ]] && cp "$src" "$CONSUMER_DIR/$f"
    done
    ensure_env
    ensure_docker
    set -a
    # shellcheck disable=SC1091
    source "$CONSUMER_DIR/.env"
    set +a
    docker compose \
      -f "$STACK_DIR/docker-compose.yml" \
      -f "$STACK_DIR/docker-compose.local.yml" \
      --project-directory "$CONSUMER_DIR" \
      --profile local pull
    echo "Stack and images updated."
    ;;
  sync)
    ensure_env
    ensure_stack
    ensure_docker
    SELF_BEFORE="$(self_sum)"
    echo "==> Stopping local stack..."
    export CONSUMER_DIR
    bash "$CONSUMER_DIR/$STACK_SCRIPTS/dev-up.sh" down
    echo ""
    echo "==> Updating local bundle + images..."
    bash "$CONSUMER_DIR/dev" update
    # update runs in a child process, so it can't re-exec this parent -
    # check for a self-update here and restart sync on the new code (the
    # repeated down/update steps are idempotent and near-instant).
    reexec_if_self_updated "$SELF_BEFORE" sync "$@"
    echo ""
    echo "==> Syncing .env to GitHub environment..."
    bash "$CONSUMER_DIR/$STACK_SCRIPTS/github-env-sync.sh" --allow-missing
    echo ""
    echo "==> Updating server..."
    bash "$CONSUMER_DIR/ops" update --quick "$@"
    echo ""
    echo "==> Starting local stack..."
    bash "$CONSUMER_DIR/$STACK_SCRIPTS/dev-up.sh" up
    ;;
  seed-roll)
    ensure_env
    ensure_stack
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/seed/roll-seeds.sh" "$@"
    ;;
  seed-report)
    ensure_stack
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/seed/report-top.sh" "$@"
    ;;
  cache)
    ensure_env
    ensure_stack
    export CONSUMER_DIR
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/cache-assets.sh" "$@"
    ;;
  start | stop | restart | status)
    ensure_stack
    ensure_docker
    export CONSUMER_DIR SERVICE_LOCAL=1
    exec bash "$CONSUMER_DIR/$STACK_SCRIPTS/service.sh" "$CMD" "$@"
    ;;
  help | --help | -h)
    usage
    ;;
  *)
    echo "Unknown command: $CMD"
    usage
    exit 1
    ;;
esac
