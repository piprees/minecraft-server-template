#!/usr/bin/env bash
# ops — Thin dispatcher to bundle operational scripts.
# Loads consumer env, then delegates to .stack/current/stack/scripts/<command>.sh
set -euo pipefail

CONSUMER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$CONSUMER_DIR"

STACK_SCRIPTS=".stack/current/stack/scripts"

ALLOWED_COMMANDS=(
  setup
  preflight
  provision
  harden
  prepare
  github-env-sync
  cloudflare
  update
  teardown
  kuma-token
  reauth-kuma
  logs
  doctor
  backup
  reset-seed
  rcon
  ssh
  chunky
  wipe-chunk
  live-logs
  live-stats
  restart-service
  start
  stop
  restart
  status
  map
  op-env
  op-sync-env
  discord-notify
  discord-cleanup
  discord-pin-sync
)

usage() {
  cat << 'EOF'
Usage: ./ops <command> [args]

Production operations - delegates to bundle scripts with your consumer
environment loaded. Every script has a usage header: read it with
  cat .stack/current/stack/scripts/<name>.sh | head -30

Health & logs:
  doctor [--threads]          Full health triage - START HERE. --threads adds
                              a JVM thread-dump verdict (main thread stuck?)
  logs [svc] [--tail N] [--grep P]
                              Log snapshot, never streams (default svc: mc)
  logs --latest [--tail N] [--grep P]
                              RAW game log file - includes what console
                              filters hide (resets each boot, 3-day retention)
  live-logs                   Stream all container logs (blocks - humans only)
  live-stats                  Stream system + container stats (blocks)

Server control:
  status [svc]                Container status (all, or one service)
  start|stop|restart <svc>    Manage one service (mc, nav-proxy, pack-web...)
  restart-service <svc>       Force-recreate one service
  update [--quick]            Pull latest bundle + images, full redeploy
  rcon "<command>"            Run an RCON command (auto local/production)
  ssh ['<command>']           Shell, or a one-shot command, on the server

World:
  chunky                      Pre-generation progress
  map render [map]            Force-render BlueMap (all maps or one)
  map status|threads <n>      Render progress / thread count
  wipe-chunk <x> <z> [dim]    Regenerate a corrupted chunk
  reset-seed <seed>           Reset the world (triple-confirmed, backup first)
  backup                      Run a restic backup now

Setup & secrets:
  setup                       First-time interactive setup
  preflight                   Validate credentials before provisioning
  provision | prepare         Create / prepare the cloud server
  harden                      SSH + firewall hardening
  cloudflare                  Tunnel + DNS configuration
  github-env-sync             Push .env to the GitHub environment (CI source)
  op-env | op-sync-env        1Password <-> .env helpers
  reauth-kuma                 Mint a fresh Kuma session token via a real
                              browser login (Playwright window; password +
                              TOTP). Run github-env-sync after, or CI wipes it
  kuma-token --paste          Paste a JWT copied from the dashboard yourself
  kuma-token --remote         Legacy socket login (Kuma 1.x only)
  teardown                    Destroy cloud resources (DESTRUCTIVE)

Discord:
  discord-notify              Send a message via the webhook
  discord-cleanup             Prune old bot messages
  discord-pin-sync            Re-sync pinned info messages
EOF
}

CMD="${1:-help}"
shift || true

if [[ "$CMD" == "help" || "$CMD" == "--help" || "$CMD" == "-h" ]]; then
  usage
  exit 0
fi

# Validate command is in the allowlist
allowed=0
for acmd in "${ALLOWED_COMMANDS[@]}"; do
  if [[ "$acmd" == "$CMD" ]]; then
    allowed=1
    break
  fi
done

if [[ $allowed -eq 0 ]]; then
  echo "Unknown command: $CMD"
  echo "Run ./ops help for a list of available commands."
  exit 1
fi

if [[ ! -d "$CONSUMER_DIR/.stack/current" ]]; then
  echo "Stack bundle not found. Pulling..."
  bash "$CONSUMER_DIR/dev" pull
fi

# Resolve script names to actual filenames
script_file="$CMD"
case "$CMD" in
  preflight)   script_file="preflight-check" ;;
  prepare)     script_file="prepare-droplet" ;;
  cloudflare)  script_file="cloudflare-setup" ;;
  update)      script_file="remote-update" ;;
  backup)      script_file="backup-now" ;;
  logs)        script_file="game-log" ;;
  reauth-kuma) script_file="kuma-token" ;;
  wipe-chunk)  script_file="wipe-chunk" ;;
  start|stop|restart|status) script_file="service" ;;
  map)                       script_file="map-render" ;;
esac

SCRIPT_PATH="$CONSUMER_DIR/$STACK_SCRIPTS/${script_file}.sh"

if [[ ! -f "$SCRIPT_PATH" ]]; then
  echo "Script not found: $SCRIPT_PATH"
  echo "Your stack bundle may be outdated. Run: ./dev update"
  exit 1
fi

# Load consumer environment before delegating
if [[ -f "$CONSUMER_DIR/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$CONSUMER_DIR/.env"
  set +a
fi

export CONSUMER_DIR

# For service.sh, pass the original command as the first argument (the action)
case "$CMD" in
  start|stop|restart|status)
    exec bash "$SCRIPT_PATH" "$CMD" "$@"
    ;;
  map)
    exec bash "$SCRIPT_PATH" "$@"
    ;;
  reauth-kuma)
    # Kuma session-token re-mint. Browser flow: log in (password + TOTP)
    # in the Chromium window it opens; the JWT is captured automatically.
    exec bash "$SCRIPT_PATH" --browser "$@"
    ;;
esac

exec bash "$SCRIPT_PATH" "$@"
