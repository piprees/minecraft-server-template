{
  // Configurable Difficulty — per-dimension and per-biome mob scaling.
  // Formula: Dimension × Biome × Depth = final multiplier.
  // See https://modrinth.com/mod/configurable-difficulty

  "enabled": true,

  // Which entity types receive attribute modifiers
  "applyToHostile": true,
  "applyToPassive": false,
  "applyToNeutral": false,

  // Which attributes to scale
  "enableHealth": true,
  "enableDamage": true,
  "enableArmor": true,
  "enableSpeed": false,
  "enableKnockback": false,
  "enableLuck": true,

  // Player luck (affects loot quality from blocks, mobs, chests)
  "playerLuckEnabled": true,

  // Depth scaling (overworld only — mobs get harder underground)
  "depthScaling": {
    "enabled": true,
    "startY": 64,
    "endY": -64,
    "minMultiplier": 1.0,
    "maxMultiplier": 1.5
  },

  // === Dimension multipliers ===
  // Base difficulty for each dimension. Custom dimensions use adventure: prefix.
  "dimensionMultipliers": {
    // Vanilla dimensions
    "minecraft:overworld": 1.0,
    "minecraft:the_nether": 1.3,
    "minecraft:the_end": 1.5,
    "paradise_lost:paradise_lost": 1.0,

    // --- Peaceful dimensions (0x = no mob scaling needed, spawning already blocked) ---
    "adventure:the_canvas": 0.0,
    "adventure:the_blossom_gardens": 0.0,

    // --- Standard 8:1 overworld (normal difficulty) ---
    "adventure:the_claymarsh": 1.0,
    "adventure:the_scorched_mesa": 1.0,
    "adventure:the_gritlands": 1.0,
    "adventure:the_roothold": 1.0,
    "adventure:the_overgrowth": 1.0,
    "adventure:the_greenreach": 1.0,
    "adventure:the_rosebluff": 1.0,
    "adventure:the_greywoods": 1.0,
    "adventure:the_miredeep": 1.0,
    "adventure:the_verdant_hollow": 1.0,
    "adventure:the_whitestone_ford": 1.0,
    "adventure:the_needlefall": 1.0,
    "adventure:the_chalk_meadows": 1.0,
    "adventure:the_stonemantle": 1.0,
    "adventure:the_ashgrove": 1.0,
    "adventure:the_crystal_vale": 1.0,
    "adventure:the_darkpine_depths": 1.0,
    "adventure:the_dripping_pines": 1.0,
    "adventure:the_ruined_timberland": 1.0,

    // --- 16:1 compact overworld (harder — tight space, fewer resources) ---
    "adventure:the_shallows": 1.8,
    "adventure:the_lantern_pools": 1.8,
    "adventure:the_dustbowl": 1.8,
    "adventure:the_lost_outpost": 1.8,
    "adventure:the_frozen_strait": 2.0,

    // --- 16:1 void (dangerous — minimal resources, high risk) ---
    "adventure:the_icebound_rift": 2.5,
    "adventure:the_sculked_beyond": 3.0,
    "adventure:the_slatemouth": 2.5,

    // --- 8:1 nether (harder than vanilla nether) ---
    "adventure:the_furnace_halls": 1.5,
    "adventure:the_bloodroot_wastes": 1.5,
    "adventure:the_basalt_spires": 1.5,
    "adventure:the_blackstone_keep": 1.5,
    "adventure:the_molten_flats": 1.5,
    "adventure:the_obsidian_sanctum": 1.8,
    "adventure:the_ember_fields": 1.5,
    "adventure:the_twisted_groves": 1.3,
    "adventure:the_soulfields": 1.5,
    "adventure:the_blighted_maw": 1.8,
    "adventure:the_teal_corruption": 1.3,
    "adventure:the_weeping_vault": 2.0,
    "adventure:the_boneyard": 1.8,
    "adventure:the_buried_age": 2.5,
    "adventure:the_luminous_caverns": 1.3,
    "adventure:the_fungal_lanterns": 1.3,

    // --- 12:1 compact nether (very hard) ---
    "adventure:the_gilded_pit": 2.5,
    "adventure:the_wailing_narrows": 2.5,
    "adventure:the_forged_depths": 2.5,

    // --- End dimensions (endgame difficulty) ---
    "adventure:the_end_citadel": 2.0,
    "adventure:the_tiled_expanse": 2.0,
    "adventure:the_pillared_void": 2.0,
    "adventure:the_catalyst_maw": 2.5,
    "adventure:the_crumbling_reaches": 2.0,
    "adventure:the_red_monument": 2.0,
    "adventure:the_fractured_halls": 2.0,

    // --- Special dimensions ---
    "adventure:the_amplified_reaches": 1.2,
    "adventure:the_underdark": 1.5,

    // --- Multi-biome blends ---
    "adventure:the_whispering_wilds": 1.2,
    "adventure:the_sun_kingdoms": 1.0,
    "adventure:the_frozen_hearth": 1.3,
    "adventure:the_highland_crossing": 1.2,

    // --- 4:1 hard compact (the challenge dimensions) ---
    "adventure:the_crucible": 2.5,
    "adventure:the_gauntlet": 3.0,

    // --- Nether blends ---
    "adventure:the_crimson_nexus": 1.5,
    "adventure:the_souldrift": 1.8,

    // --- Large biomes ---
    "adventure:the_endless_expanse": 1.0,

    // --- Paradise Lost dimensions (relaxed) ---
    "adventure:the_glacial_drift": 0.8,
    "adventure:the_sunken_temple": 0.8,
    "adventure:the_snowbound_isle": 0.8,
    "adventure:the_abyssal_shrine": 1.0,
    "adventure:the_pale_reach": 1.0,
    "adventure:the_violet_spire": 1.0
  },

  // === Player luck per dimension ===
  // Higher luck = better loot from chests, mobs, and blocks
  "dimensionLuckMultipliers": {
    // Peaceful/creative worlds — generous loot
    "adventure:the_blossom_gardens": 3.0,
    "adventure:the_canvas": 2.0,

    // Super lucky dimensions — reward exploration
    "adventure:the_crystal_vale": 2.0,
    "adventure:the_buried_age": 2.5,
    "adventure:the_gilded_pit": 2.0,
    "adventure:the_luminous_caverns": 1.5,

    // Hard dimensions — better loot to compensate
    "adventure:the_crucible": 1.5,
    "adventure:the_gauntlet": 2.0,
    "adventure:the_sculked_beyond": 2.0,
    "adventure:the_weeping_vault": 1.5,
    "adventure:the_catalyst_maw": 1.8
  }
}
