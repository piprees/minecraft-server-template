{
	// Radius in blocks around the campfire where healing applies.
	"healingRadius": 10,

	// Regeneration effect duration in seconds (re-applied while in range).
	"regenerationDuration": 60,

	// Regeneration level (1 = Regeneration I, 2 = Regeneration II).
	"regenerationLevel": 1,

	// Whether passive mobs (animals) also receive healing.
	"healPassiveMobs": true,

	// Campfire must be lit (not extinguished) to heal.
	"requireLitCampfire": true,

	// Whether soul campfires also heal.
	"enableSoulCampfireHealing": true
}
