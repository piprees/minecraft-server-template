<?xml version="1.0" encoding="UTF-8"?>
<!-- Custom log4j2 config - filters noisy messages and limits log growth.
     Mounted into the mc container via JVM_OPTS in docker-compose.yml.

     IMPORTANT: Only filter cosmetic noise here — mod compat warnings,
     debug chatter, polling spam. Never suppress real errors, even noisy
     ones (e.g. c2me chunk upgrade failures). Those go in doctor.sh's
     grep filter so they don't inflate the error count but stay visible
     in raw logs for diagnosis. -->
<Configuration status="WARN">
    <Properties>
        <Property name="logPattern">[%d{HH:mm:ss}] [%t/%level]: %msg{nolookups}%n</Property>
    </Properties>
    <Appenders>
        <Console name="SysOut" target="SYSTEM_OUT">
            <PatternLayout pattern="${logPattern}" />
            <Filters>
                <!-- RCON listener thread start/stop spam (runs every healthcheck) -->
                <RegexFilter regex=".*Thread RCON Client.*started.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Thread RCON Client.*stopped.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Vinery missing trade item warnings (harmless mod compat issue) -->
                <RegexFilter regex=".*Vinery Villager Trade Item not found.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Loot table cross-mod reference warnings (mods referencing each other's loot tables) -->
                <RegexFilter regex=".*Unknown loot table called farmersdelight.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- owo-lib DataResult stack traces (debug noise from expanded-bow-enchanting) -->
                <RegexFilter regex=".*owo.*addStackTraceToException.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Autopause polling noise -->
                <RegexFilter regex=".*\[Autopause\].*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Distant Horizons chunk loading warnings (expected during exploration) -->
                <RegexFilter regex=".*\[DistantHorizons\].*chunk.*timeout.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Supplementaries registry warnings (harmless cross-mod compat) -->
                <RegexFilter regex=".*supplementaries.*registry.*not found.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- C2ME parallel worldgen noise (harmless during chunk generation) -->
                <RegexFilter regex=".*\[c2me\].*debug.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Ignoring unknown attribute.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Couldn't find template pool reference.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Block-attached entity at invalid position.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Failed to parse either.*Not a string: null.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- ModernFix class loading noise -->
                <RegexFilter regex=".*\[ModernFix\].*Skipping.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- DramaticDoors + Woodworks sawmill recipes (Woodworks is Forge-only, no Fabric build) -->
                <RegexFilter regex=".*woodworks:sawmill.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- DramaticDoors + Chipped cross-mod door variant recipes (item IDs don't match our Chipped version) -->
                <RegexFilter regex=".*dramaticdoors:tall_chipped_.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*dramaticdoors:recipes/redstone/tall_chipped_.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- When Dungeons Arise advancement format issues (old JSON format, mod bug) -->
                <RegexFilter regex=".*dungeons_arise:find_.*No key id in MapLike.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Natures Spirit missing tag reference (harmless) -->
                <RegexFilter regex=".*Couldn't load tag c:stripped_wood.*natures_spirit.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Moogs structure loot table validation (optional parameter in wrong context) -->
                <RegexFilter regex=".*loot_table.*mns:chests.*attacking_entity.*" onMatch="DENY" onMismatch="NEUTRAL" />
            </Filters>
        </Console>
        <RollingRandomAccessFile name="File" fileName="logs/latest.log"
                                 filePattern="logs/%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${logPattern}" />
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB" />
                <OnStartupTriggeringPolicy />
            </Policies>
            <!-- Keep 3 days of compressed logs, delete older ones -->
            <DefaultRolloverStrategy max="3">
                <Delete basePath="logs" maxDepth="1">
                    <IfFileName glob="*.log.gz" />
                    <IfLastModified age="3d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingRandomAccessFile>
    </Appenders>
    <Loggers>
        <!-- Suppress Distant Horizons info-level chatter -->
        <Logger name="com.seibel.distanthorizons" level="warn" additivity="false">
            <AppenderRef ref="SysOut" />
            <AppenderRef ref="File" />
        </Logger>
        <Root level="info">
            <AppenderRef ref="SysOut" />
            <AppenderRef ref="File" />
        </Root>
    </Loggers>
</Configuration>
