<?xml version="1.0" encoding="UTF-8"?>
<!-- Custom log4j2 config - filters noisy messages and limits log growth.
     Mounted into the mc container via JVM_OPTS in docker-compose.yml.

     IMPORTANT: Only filter cosmetic noise here — mod compat warnings,
     debug chatter, polling spam. Never suppress real errors, even noisy
     ones (e.g. c2me chunk upgrade failures). Those go in doctor.sh's
     grep filter so they don't inflate the error count but stay visible
     in raw logs for diagnosis. -->
<Configuration status="WARN">
    <Properties>
        <Property name="logPattern">[%d{HH:mm:ss}] [%t/%level]: %msg{nolookups}%n</Property>
    </Properties>
    <Appenders>
        <Console name="SysOut" target="SYSTEM_OUT">
            <!-- Console traces are for humans: filtered %xEx collapses JDK
                 stream/collection plumbing and rxjava scheduler frames into
                 "... suppressed" lines, leaving the game/mod frames that
                 actually identify the fault. The File appender below keeps
                 FULL traces — grep data/logs/latest.log for forensics. -->
            <PatternLayout pattern="[%d{HH:mm:ss}] [%t/%level]: %msg{nolookups}%n%xEx{filters(java.util.stream,java.util.Spliterator,java.util.Spliterators,java.util.ArrayList,java.util.Iterator,java.util.PrimitiveIterator,java.util.Optional,java.util.concurrent,com.google.common.collect,io.reactivex.rxjava3)}" />
            <Filters>
                <!-- RCON client/listener thread start/stop spam (hundreds per deploy) -->
                <RegexFilter regex=".*Thread RCON.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Mixin refmap warnings (harmless, "development environment" noise) -->
                <RegexFilter regex=".*refmap.*could not be read.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Mixin target not found warnings (cross-mod optional compat) -->
                <RegexFilter regex=".*@Mixin target.*was not found.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Error loading class:.*ClassNotFoundException.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Bountiful pool configuration warnings (cosmetic, pools still work).
                     (?s) is required: RegexFilter full-matches the message and these
                     messages are multi-line. -->
                <RegexFilter regex="(?s).*has been loaded, but is not attached to any existing data.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Quark color set definitions (mod not installed) -->
                <RegexFilter regex=".*Failed to load custom color set definition.*quark.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Missing tags for lead (no lead mod installed) -->
                <RegexFilter regex=".*Not all defined tags.*c:ingots/lead.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- C2ME/Lithium/ModernFix mixin override notices -->
                <RegexFilter regex=".*Option.*overriden.*by mods.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Method overwrite conflict.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Static binding violation.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Distant Horizons GC warnings (informational, not actionable;
                     multi-line, hence (?s)). Also disabled at source via the
                     DH config keys in deploy.sh/dev-up.sh. -->
                <RegexFilter regex="(?s).*Distant Horizons.*Garbage.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex="(?s).*Distant Horizons.*G1.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- OPAC missing party/permission system (configured for mods we don't have) -->
                <RegexFilter regex=".*configured.*isn't registered.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Lithium mixin options being force-disabled (normal mod interaction) -->
                <RegexFilter regex=".*Force-disabling mixin.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- CrittersAndCompanions shift warning -->
                <RegexFilter regex=".*Shift\.BY.*exceeds the maximum.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Vinery missing trade item warnings (harmless mod compat issue) -->
                <RegexFilter regex=".*Vinery Villager Trade Item not found.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Loot table cross-mod reference warnings (mods referencing each other's loot tables) -->
                <RegexFilter regex=".*Unknown loot table called farmersdelight.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- owo-lib DataResult stack traces (debug noise from expanded-bow-enchanting) -->
                <RegexFilter regex=".*owo.*addStackTraceToException.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Autopause polling noise -->
                <RegexFilter regex=".*\[Autopause\].*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Distant Horizons chunk loading warnings (expected during exploration) -->
                <RegexFilter regex=".*\[DistantHorizons\].*chunk.*timeout.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Supplementaries registry warnings (harmless cross-mod compat) -->
                <RegexFilter regex=".*supplementaries.*registry.*not found.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- C2ME parallel worldgen noise (harmless during chunk generation) -->
                <RegexFilter regex=".*\[c2me\].*debug.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Ignoring unknown attribute.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Couldn't find template pool reference.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Block-attached entity at invalid position.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Failed to parse either.*Not a string: null.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- BlueMap inotify exhaustion (harmless — maps still render, just won't auto-update) -->
                <RegexFilter regex=".*inotify instances reached.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*watch-service.*stopped unexpectedly.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*Failed to create update-watcher for map.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- ModernFix class loading noise -->
                <RegexFilter regex=".*\[ModernFix\].*Skipping.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- DramaticDoors dead optional integrations: its bundled recipes for
                     Woodworks' sawmill (Forge-only) and mismatched Chipped door items
                     can never parse here. The distinguishing text lives in the
                     EXCEPTION, which RegexFilter can't see — filter the vanilla
                     "Parsing error loading recipe <id>" message itself. Working
                     sawmill recipes come from universal-sawmill's generated pack. -->
                <RegexFilter regex="Parsing error loading recipe dramaticdoors:.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex="Parsing error loading custom advancement dramaticdoors:.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- When Dungeons Arise data bugs (pre-1.21 item predicate format) -->
                <RegexFilter regex="Parsing error loading custom advancement dungeons_arise:.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- The follow-up summary line for the same known-broken advancements -->
                <RegexFilter regex="Couldn't load advancements: .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- FastNetherPortals datapack references a gamerule that doesn't exist on Fabric -->
                <RegexFilter regex="Failed to load function fnp:load" onMatch="DENY" onMismatch="NEUTRAL" />
                <RegexFilter regex=".*missing following references: fnp:load.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Mods registering entities/blocks without datafixers — standard modded
                     noise, harmless (datafixers only matter for vanilla version upgrades) -->
                <RegexFilter regex="No data fixer registered for .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Lithium option cascade: supplementaries ships a compat override
                     (mixin.util.block_tracking=false) and Lithium logs every dependent
                     option it therefore disables -->
                <RegexFilter regex="Option 'mixin\..*' requires 'mixin\.util\.block_tracking=true'.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Natures Spirit missing tag reference (harmless) -->
                <RegexFilter regex=".*Couldn't load tag c:stripped_wood.*natures_spirit.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Fabric registry-sync migration aliases pointing at IDs not
                     registered in this pack (dungeons_reborn/skyblock renames).
                     Dead aliases are inert — nothing in a world references them. -->
                <RegexFilter regex="Adding \S+ as an alias for \S+, but the latter doesn't exist in registry ResourceKey.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Worldgen height-range quirk in custom dimensions (c2me worker;
                     the feature simply doesn't place — cosmetic) -->
                <RegexFilter regex="Empty height range: .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- POI re-registration on chunk reload/upgrade — vanilla recovers
                     by keeping the existing entry; recurring with c2me -->
                <RegexFilter regex="POI data mismatch: already registered at .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- Pre-1.21 sculk sensor NBT that DFU can't parse; the listener
                     resets itself and the sensor works from then on -->
                <RegexFilter regex="Failed to parse vibration listener for Sculk Sensor: .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- yungsapi mixin duplicate-method discards (per worker thread,
                     every boot; upstream cosmetic) -->
                <RegexFilter regex="Discarding @Unique public method .*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- c2me rewrites-chunk-system race: onChunkStatusChange walks
                     ServerEntityManager tracking lists while another task
                     mutates them -> CME, caught by the executor. One
                     bookkeeping pass is abandoned and redone on the next
                     status change; no serialization involved, hundreds/hour
                     under Chunky at zero observed harm. CAVEAT: this is
                     vanilla's generic chunk-executor error message, so any
                     OTHER exception on that executor is console-hidden too —
                     data/logs/latest.log keeps every occurrence (file appender
                     is unfiltered). Real fix: c2me bump past 0.4.00.19. -->
                <RegexFilter regex="Error executing task on Chunk source main thread executor.*" onMatch="DENY" onMismatch="NEUTRAL" />
                <!-- (Epic Dungeons CamelCase loot ids are FIXED at source by
                     scripts/patch-mod-data.py — 'Failed to load chunk' stays
                     unfiltered so any new cause is visible immediately.) -->
                <!-- Moogs structure loot table validation (optional parameter in wrong context) -->
                <RegexFilter regex=".*loot_table.*mns:chests.*attacking_entity.*" onMatch="DENY" onMismatch="NEUTRAL" />
            </Filters>
        </Console>
        <RollingRandomAccessFile name="File" fileName="logs/latest.log"
                                 filePattern="logs/%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${logPattern}" />
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB" />
                <OnStartupTriggeringPolicy />
            </Policies>
            <!-- Keep 3 days of compressed logs, delete older ones -->
            <DefaultRolloverStrategy max="3">
                <Delete basePath="logs" maxDepth="1">
                    <IfFileName glob="*.log.gz" />
                    <IfLastModified age="3d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingRandomAccessFile>
    </Appenders>
    <Loggers>
        <!-- Suppress Distant Horizons info-level chatter -->
        <Logger name="com.seibel.distanthorizons" level="warn" additivity="false">
            <AppenderRef ref="SysOut" />
            <AppenderRef ref="File" />
        </Logger>
        <Root level="info">
            <AppenderRef ref="SysOut" />
            <AppenderRef ref="File" />
        </Root>
    </Loggers>
</Configuration>
