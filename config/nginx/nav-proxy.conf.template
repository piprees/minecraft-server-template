        sub_filter '<title>' '<meta property="og:site_name" content="${BRAND_NAME}"><meta property="og:title" content="${BRAND_NAME} - Server Status"><meta property="og:description" content="Live uptime and status for ${BRAND_NAME}, a modded Minecraft adventure server."><meta property="og:image" content="https://pack.${DOMAIN}/og-image.jpg"><meta property="og:type" content="website"><meta property="og:url" content="https://status.${DOMAIN}/"><meta name="twitter:card" content="summary_large_image"><link rel="icon" href="https://pack.${DOMAIN}/favicon.ico"><link rel="apple-touch-icon" href="https://pack.${DOMAIN}/apple-touch-icon.png"><title>';

