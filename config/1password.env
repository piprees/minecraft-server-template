# 1Password secret references (op:// URIs).
#
# ITEM NAME IS PER-SERVER: op-env.sh rewrites the literal "Minecraft Server"
# below to "Minecraft Server (<BRAND_SLUG>)" (or $OP_ITEM_NAME) at read time,
# and op-sync-env.sh writes to the same per-brand item. One item per server -
# a shared item means one repo's sync clobbers another's rotated credentials.
# Sections: "local" / "prod".
#
# Usage:
#   ./scripts/op-env.sh local > .env
#   OP_ITEM_NAME="Minecraft Server (myslug)" ./scripts/op-env.sh local > .env
#   (op run --env-file consumers get the plain item name - prefer op-env.sh)

# --- Hetzner Cloud (primary provider) -----------------------------------------
HETZNER_API_TOKEN=op://Dev/Minecraft Server/HETZNER_API_TOKEN

# --- DigitalOcean (legacy, kept for reference) --------------------------------
DO_API_TOKEN=op://Dev/Minecraft Server/DO_API_TOKEN

# --- Cloudflare (shared) ------------------------------------------------------
CLOUDFLARE_API_TOKEN=op://Dev/Minecraft Server/CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=op://Dev/Minecraft Server/CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_ZONE_ID=op://Dev/Minecraft Server/CLOUDFLARE_ZONE_ID

# --- Discord (shared) ---------------------------------------------------------
DISCORD_BOT_TOKEN=op://Dev/Minecraft Server/DISCORD_BOT_TOKEN
DISCORD_CHANNEL_ID=op://Dev/Minecraft Server/DISCORD_CHANNEL_ID
DISCORD_CHAT_CHANNEL_ID=op://Dev/Minecraft Server/DISCORD_CHAT_CHANNEL_ID
DISCORD_WEBHOOK_URL=op://Dev/Minecraft Server/DISCORD_WEBHOOK_URL

# --- Cloudflare R2 (shared) ---------------------------------------------------
R2_ACCOUNT_ID=op://Dev/Minecraft Server/R2_ACCOUNT_ID
R2_BUCKET=op://Dev/Minecraft Server/R2_BUCKET
R2_ACCESS_KEY_ID=op://Dev/Minecraft Server/R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=op://Dev/Minecraft Server/R2_SECRET_ACCESS_KEY
RESTIC_PASSWORD=op://Dev/Minecraft Server/RESTIC_PASSWORD

# --- Cloudflare Tunnel --------------------------------------------------------
CLOUDFLARE_TUNNEL_ID=op://Dev/Minecraft Server/CLOUDFLARE_TUNNEL_ID

# --- Discord ------------------------------------------------------------------
DISCORD_GUILD_ID=op://Dev/Minecraft Server/DISCORD_GUILD_ID
DISCORD_ADMIN_ROLE_ID=op://Dev/Minecraft Server/DISCORD_ADMIN_ROLE_ID
DISCORD_PLAYER_ROLE_ID=op://Dev/Minecraft Server/DISCORD_PLAYER_ROLE_ID
DISCORD_BOT_ROLE_ID=op://Dev/Minecraft Server/DISCORD_BOT_ROLE_ID
DISCORD_WELCOME_CHANNEL_ID=op://Dev/Minecraft Server/DISCORD_WELCOME_CHANNEL_ID
DISCORD_WELCOME_MESSAGE_ID=op://Dev/Minecraft Server/DISCORD_WELCOME_MESSAGE_ID
DISCORD_INVITE_URL=op://Dev/Minecraft Server/DISCORD_INVITE_URL

# --- Brand / instance config (non-secret, needed for full recovery) -----------
BRAND_NAME=op://Dev/Minecraft Server/BRAND_NAME
BRAND_SLUG=op://Dev/Minecraft Server/BRAND_SLUG
SEED=op://Dev/Minecraft Server/SEED
SPAWN_X=op://Dev/Minecraft Server/SPAWN_X
SPAWN_Y=op://Dev/Minecraft Server/SPAWN_Y
SPAWN_Z=op://Dev/Minecraft Server/SPAWN_Z

# --- Per-environment secrets ---------------------------------------------------
RCON_PASSWORD=op://Dev/Minecraft Server/${MC_ENV:-local}/RCON_PASSWORD
KUMA_PASSWORD=op://Dev/Minecraft Server/${MC_ENV:-local}/KUMA_PASSWORD
KUMA_API_KEY=op://Dev/Minecraft Server/KUMA_UPTIME_CHECKS_API_KEY
KUMA_USERNAME=op://Dev/Minecraft Server/KUMA_USERNAME
ONLINE_MODE=op://Dev/Minecraft Server/${MC_ENV:-local}/ONLINE_MODE
